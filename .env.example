# Root .env for docker-compose
# Copy to .env and fill in values before running: docker compose up --build
#
# Backend vars are also read from backend/.env — copy backend/.env.example to backend/.env
# Frontend VITE_ vars are baked into the image at build time

# ── Firebase (frontend build args) ───────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Backend API URL (used by browser to reach the backend) ───────────────────
# Local:      http://localhost:3001
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:3001

# ── PostgreSQL (docker-compose postgres service) ─────────────────────────────
# These are gitignored — never commit real credentials
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=localresourcesharing

# ── CORS (backend allowed origins) ───────────────────────────────────────────
# Comma-separated list of frontend URLs the backend will accept requests from
# Default (docker-compose): http://localhost
# Production example: ALLOWED_ORIGINS=https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost
