# Backend Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL="file:./prisma/dev.db"

# Server
PORT=3001
NODE_ENV=development

# Firebase Admin SDK (Get from Firebase Console > Project Settings > Service Accounts > Generate Private Key)
# Download the JSON file and copy these values:
FIREBASE_PROJECT_ID=your-project-id-here
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Multi_Line_Private_Key_Here\n-----END PRIVATE KEY-----\n"

# IMPORTANT: Keep the \n characters in FIREBASE_PRIVATE_KEY - don't replace with actual newlines!

# CORS Settings (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
